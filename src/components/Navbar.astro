    <div class="flex items-center gap-[7px] text-[14px] text-[#9b72c0] tracking-[0.1em] mt-4">
      <div class="orb w-[7px] h-[7px] rounded-full bg-[#ff2d8a] border border-[rgba(255,133,192,0.4)] animate-[breathe_2.5s_infinite]"></div>
      Available
    </div>
  </div>
