<!-- Mobile menu panel -->
<div id="mobile-menu" class="fixed inset-0 z-50 hidden md:hidden">
  <div class="absolute inset-0 bg-[rgba(7,1,15,0.97)] backdrop-blur-[8px]"></div>
  <div class="relative z-10 flex flex-col items-center justify-center h-full gap-8">
    <button id="menu-close" class="absolute top-5 right-5 text-[#9b72c0] text-[24px] cursor-pointer hover:text-[#ff85c0] transition-colors border-none bg-transparent">
      <i class="ti ti-x"></i>
    </button>
    <a href="#" class="text-[20px] text-[#c9a8e8] no-underline tracking-[0.15em] uppercase font-cinzel hover:text-[#ff85c0] transition-colors">Works</a>
