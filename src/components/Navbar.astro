<nav class="flex items-center justify-between px-4 md:px-9 py-[18px] border-b border-[rgba(196,75,255,0.18)] bg-[rgba(7,1,15,0.94)] backdrop-blur-[12px] sticky top-0 z-10">
  <div class="flex items-center gap-2 md:gap-4">
