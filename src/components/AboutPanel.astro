            <p class="text-[14px] text-[#c9a8e8] leading-[1.9] font-light">
              Tools I work with: Blender, ZBrush, Substance Painter, Unreal Engine 5, Cinema 4D, 3ds Max, and After Effects.
            </p>
            <div class="flex gap-4 mt-4 pt-6 border-t border-[rgba(196,75,255,0.08)]">
              <a href="https://www.youtube.com/@ailens.c" target="_blank" class="text-[#9b72c0] text-[20px] no-underline transition-colors duration-200 hover:text-[#ff85c0]"><i class="ti ti-brand-youtube"></i></a>
              <a href="https://discord.gg/cTZBAC7hH" target="_blank" class="text-[#9b72c0] text-[20px] no-underline transition-colors duration-200 hover:text-[#ff85c0]"><i class="ti ti-brand-discord"></i></a>
              <a href="https://www.instagram.com/ailens.c/" target="_blank" class="text-[#9b72c0] text-[20px] no-underline transition-colors duration-200 hover:text-[#ff85c0]"><i class="ti ti-brand-instagram"></i></a>
              <a href="https://www.linkedin.com/in/ailencolazo77/" target="_blank" class="text-[#9b72c0] text-[20px] no-underline transition-colors duration-200 hover:text-[#ff85c0]"><i class="ti ti-brand-linkedin"></i></a>
              <a href="https://artstation.com" target="_blank" class="text-[#9b72c0] text-[20px] no-underline transition-colors duration-200 hover:text-[#ff85c0]"><i class="ti ti-brand-artstation"></i></a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  #about-panel.opening #about-content {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
const panel = document.getElementById("about-panel");
const overlay = document.getElementById("about-overlay");
const closeBtn = document.getElementById("about-close");
const openBtns = document.querySelectorAll("[data-open-about]");
let animId = null;
const particles = [];

function openPanel() {
  panel?.classList.remove("hidden");
  setTimeout(() => panel?.classList.add("opening"), 30);
  document.body.style.overflow = "hidden";
  initCanvas();
}
function closePanel() {
  panel?.classList.remove("opening");
  panel?.classList.add("hidden");
  document.body.style.overflow = "";
  stopCanvas();
}
openBtns.forEach((btn) => btn.addEventListener("click", openPanel));
closeBtn?.addEventListener("click", closePanel);
overlay?.addEventListener("click", closePanel);
document.addEventListener("keydown", (e) => { if (e.key === "Escape") closePanel(); });

class P {
  constructor(w, h) { this.w = w; this.h = h; this.reset(); }
  reset() {
    this.x = Math.random() * this.w; this.y = Math.random() * this.h;
    this.size = 8 + Math.random() * 14; this.angle = Math.random() * Math.PI * 2;
    this.rotSpeed = (Math.random() - 0.5) * 0.03;
    this.phase = Math.random() * Math.PI * 2; this.type = Math.floor(Math.random() * 3);
    this.opacity = 0.5 + Math.random() * 0.4;
  }
  update(mx, my) {
    const dx = mx - this.x, dy = my - this.y, dist = Math.sqrt(dx * dx + dy * dy);
    if (dist > 30) { this.x += dx * 0.02; this.y += dy * 0.02; }
    else { this.x += Math.cos(this.angle + this.phase) * 0.3; this.y += Math.sin(this.angle + this.phase) * 0.3; }
    this.angle += this.rotSpeed;
  }
  draw(ctx) {
    const now = Date.now() * 0.002, pulse = 0.7 + 0.3 * Math.sin(now + this.phase), a = this.opacity * pulse;
    ctx.save(); ctx.translate(this.x, this.y); ctx.rotate(this.angle);
    ctx.shadowColor = this.type === 0 ? "rgba(196,75,255,0.4)" : this.type === 1 ? "rgba(255,45,138,0.4)" : "rgba(214,136,255,0.4)";
    ctx.shadowBlur = 12 + Math.sin(now + this.phase) * 4;
    const r = this.size; ctx.lineWidth = 0.8 + Math.sin(now + this.phase) * 0.3;
    if (this.type === 0) {
      ctx.strokeStyle = `rgba(196,75,255,${a})`; ctx.beginPath();
      for (let i = 0; i < 6; i++) { const ang = (Math.PI / 3) * i - Math.PI / 6; const px = Math.cos(ang) * r, py = Math.sin(ang) * r; i === 0 ? ctx.moveTo(px, py) : ctx.lineTo(px, py); }
      ctx.closePath(); ctx.stroke(); ctx.fillStyle = `rgba(196,75,255,${a * 0.04})`; ctx.fill();
    } else if (this.type === 1) {
      ctx.strokeStyle = `rgba(255,45,138,${a})`; ctx.beginPath();
      ctx.moveTo(0, -r); ctx.lineTo(r * 0.8, 0); ctx.lineTo(0, r); ctx.lineTo(-r * 0.8, 0);
      ctx.closePath(); ctx.stroke(); ctx.fillStyle = `rgba(255,45,138,${a * 0.04})`; ctx.fill();
    } else {
      ctx.strokeStyle = `rgba(214,136,255,${a})`; ctx.beginPath(); ctx.arc(0, 0, r, 0, Math.PI * 2); ctx.stroke();
      ctx.strokeStyle = `rgba(255,45,138,${a * 0.4})`; ctx.beginPath(); ctx.arc(0, 0, r * 0.65, 0, Math.PI * 2); ctx.stroke();
      ctx.fillStyle = `rgba(255,133,192,${a * 0.6})`; ctx.shadowBlur = 20; ctx.beginPath(); ctx.arc(0, 0, 2, 0, Math.PI * 2); ctx.fill();
    }
    ctx.shadowBlur = 0; ctx.restore();
  }
}

function initCanvas() {
  const canvas = document.getElementById("about-canvas"); if (!canvas) return;
  const ctx = canvas.getContext("2d");
  let W = canvas.width = window.innerWidth, H = canvas.height = window.innerHeight;
  const mouse = { x: W / 2, y: H / 2 };
  for (let i = 0; i < 40; i++) particles.push(new P(W, H));
  window.addEventListener("resize", () => { W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; });
  document.addEventListener("mousemove", (e) => { mouse.x = e.clientX; mouse.y = e.clientY; });
  function animate() {
    ctx.clearRect(0, 0, W, H);
    for (let i = particles.length - 1; i >= 0; i--) { const p = particles[i]; p.update(mouse.x, mouse.y); p.draw(ctx); if (p.x < -100 || p.x > W + 100 || p.y < -100 || p.y > H + 100) p.reset(); }
    for (const p of particles) { const dx = p.x - mouse.x, dy = p.y - mouse.y, d = Math.sqrt(dx * dx + dy * dy); if (d < 200) { const a = (1 - d / 200) * 0.15; ctx.save(); ctx.shadowColor = `rgba(196,75,255,${a * 0.5})`; ctx.shadowBlur = 8; ctx.strokeStyle = `rgba(196,75,255,${a})`; ctx.lineWidth = 0.6; ctx.beginPath(); ctx.moveTo(mouse.x, mouse.y); ctx.lineTo(p.x, p.y); ctx.stroke(); ctx.restore(); } }
    animId = requestAnimationFrame(animate);
  }
  animate();
}
function stopCanvas() { if (animId) { cancelAnimationFrame(animId); animId = null; } particles.length = 0; }
</script>
